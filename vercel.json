{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "cd argus-app && npm install",
  "buildCommand": "cd argus-app && npm run setup-cesium && npm run build",
  "outputDirectory": "argus-app/.next",
  "functions": {
    "argus-app/src/app/api/**/*.ts": {
      "maxDuration": 25
    }
  }
}

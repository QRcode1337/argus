# Cesium Ion access token (free at https://ion.cesium.com/tokens)
NEXT_PUBLIC_CESIUM_ION_TOKEN=

# Optional public client endpoints (defaults point at local proxy routes)
NEXT_PUBLIC_OPENSKY_ENDPOINT=/api/feeds/opensky
NEXT_PUBLIC_CELESTRAK_ENDPOINT=/api/feeds/celestrak
NEXT_PUBLIC_USGS_ENDPOINT=/api/feeds/usgs
NEXT_PUBLIC_ADSB_ENDPOINT=/api/feeds/adsb-military

# Upstream proxy targets
OPENSKY_ENDPOINT=https://opensky-network.org/api/states/all
CELESTRAK_ENDPOINT=https://celestrak.org/NORAD/elements/gp.php?GROUP=active&FORMAT=json
USGS_ENDPOINT=https://earthquake.usgs.gov/earthquakes/feed/v1.0/summary/all_day.geojson
ADSB_MIL_ENDPOINT=https://api.adsb.lol/v2/mil

# Optional if your ADS-B provider requires auth
ADSB_MIL_API_KEY=

# Windy Webcams API key (free at https://api.windy.com)
WINDY_WEBCAM_API_KEY=

# Federal Reserve Economic Data (FRED)
FRED_API_KEY=
FRED_SERIES_ID=DFF

# AISStream API
AISSTREAM_API_KEY=
AISSTREAM_ENDPOINT=https://api.aisstream.io/v0/vessels

# Threat/Outage feeds
OTX_API_KEY=
CLOUDFLARE_RADAR_TOKEN=

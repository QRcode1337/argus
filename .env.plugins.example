# Copy values into /home/volta/argus/.env

# GlitchTip
GLITCHTIP_SECRET_KEY=replace-with-very-long-random-string
GLITCHTIP_DB_PASSWORD=replace-with-strong-password
GLITCHTIP_DOMAIN=https://errors.yourdomain.com
